# ================================
# DIRECTUS CONFIG
# ================================
HOST=0.0.0.0
PORT=8055

# ================================
# DATABASE (PostgreSQL on Railway)
# ================================
DB_CLIENT=pg
DB_CONNECTION_STRING=${DATABASE_URL}

# ================================
# SECURITY — generate random values
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ================================
SECRET=REPLACE_WITH_RANDOM_SECRET
ADMIN_EMAIL=admin@yourlimo.com
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ================================
# CORS — add your frontend URL
# ================================
CORS_ENABLED=true
CORS_ORIGIN=true

# ================================
# PUBLIC URL (set after Railway deploys)
# ================================
PUBLIC_URL=https://YOUR_PROJECT.up.railway.app

# ================================
# EMAIL (optional — for booking notifications)
# ================================
# EMAIL_FROM=noreply@yourlimo.com
# EMAIL_TRANSPORT=smtp
# EMAIL_SMTP_HOST=smtp.sendgrid.net
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=apikey
# EMAIL_SMTP_PASSWORD=YOUR_SENDGRID_KEY
